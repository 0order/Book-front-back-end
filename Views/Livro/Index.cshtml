@model GerenciamentoLivros.Models.Livro;

@{
    ViewData["Title"] = "Clube do Livro - Cadastro";
    Layout = null;
}

<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Merriweather:wght@300;400;700&display=swap" rel="stylesheet">

    <style>

        body {
            background-image: url('/NovaPasta/FUNDO2.jpg'), url('/NovaPasta/fundo.jpg');
            background-size: contain, cover;
            background-position: center, center;
            background-repeat: no-repeat, no-repeat;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            margin: 0;
            background-color: #f5f5f5;
        }


        .livro-acoes-container {
            width: 24vw;
            height: 60vh;
            margin-top: calc(5vh - 0cm - 5cm);
            margin-left: calc(13vw + -16cm - 1.5cm);
            padding: 20px;
            background-color: transparent;
            display: flex;
            flex-direction: column;
            align-items: flex-start;
            justify-content: flex-start;
            text-align: left;
        }


        .livro-form-group {
            margin-bottom: 5px;
            width: 100%;
        }


        .livro-label {
            font-family: 'Merriweather', serif;
            font-size: 1.0rem;
            font-weight: 700;
            color: #3e2723;
            display: block;
            margin-top: 5px;
        }


        .form-control-livro {
            font-family: 'Merriweather', serif;
            font-size: 1rem;
            border: none;
            border-bottom: 1px dashed #3e2723;
            background-color: transparent;
            color: #3e2723;
            padding: 10px 0;

            width: calc(100% + 1cm);
            max-width: none;
        }


        .btn-salvar-livro {
            font-family: 'Merriweather', serif;
            font-size: 0.9rem;
            font-weight: 700;
            margin-top: calc(30px - 0.5cm);
            width: calc(100% - 1.5cm);
            padding: 4px 0;
            background-color: rgba(62, 39, 35, 0.8);
            border: 2px solid #ae8e68;
            color: #f0e6c4;
            transition: all 0.2s;
        }

            .btn-salvar-livro:hover {
                background-color: #3e2723;
                color: #ffffff;
                border-color: #f0e6c4;
            }

        .btn-navegar-direita {
            position: absolute;
            top: 41%;
            left: 62%;
            transform: translateX(-50%);
            font-family: 'Merriweather', serif;
            font-size: 1.05rem;
            font-weight: 700;
            padding: 12px 25px;
            min-width: 200px;
            background-color: rgba(62, 39, 35, 0.88);
            border: 2px solid #ae8e68;
            color: #f0e6c4;
            text-decoration: none;
            border-radius: 6px;
            transition: 0.2s;
            text-align: center;
        }

            .btn-navegar-direita:hover {
                background-color: #3e2723;
                color: #ffffff;
                border-color: #f0e6c4;
            }
        
    </style>
</head>
<body>

    <div class="livro-acoes-container">
        <a href="/Livro/Listar" class="btn-navegar-direita">Ver Lista de Livros</a>

        <h2 class="mb-4" style="font-family: 'Merriweather', serif; color: #3e2723;">
            @((Model != null && Model.Codigo > 0)
                        ? "Alteração de Livro"
                        : "Cadastro de Livro")
        </h2>

        <form asp-action="@((Model != null && Model.Codigo > 0) ? "Alterar" : "Cadastrar")" method="post">

            <div class="livro-form-group">
                <label asp-for="NomeLivro" class="livro-label">Nome do Livro</label>
                <input asp-for="NomeLivro" type="text" class="form-control-livro" placeholder="DIGITE O NOME DO LIVRO" required>
            </div>

            <div class="livro-form-group">
                <label asp-for="NomeAutor" class="livro-label">Nome do Autor</label>
                <input asp-for="NomeAutor" type="text" class="form-control-livro" placeholder="DIGITE O NOME DO AUTOR" required>
            </div>

            <div class="livro-form-group">
                <label asp-for="Genero" class="livro-label">Gênero</label>
                <input asp-for="Genero" type="text" class="form-control-livro" placeholder="DIGITE O GÊNERO DO LIVRO" required>
            </div>

            <div class="livro-form-group">
                <label asp-for="QtPaginas" class="livro-label">Quantidade de Páginas</label>
                <input asp-for="QtPaginas" type="number" class="form-control-livro" placeholder="0" required>
            </div>

            <div class="livro-form-group">
                <label asp-for="Editora" class="livro-label">Editora</label>
                <input asp-for="Editora" type="text" class="form-control-livro" placeholder="DIGITE A EDITORA" required>
            </div>

            <div class="livro-form-group">
                <label asp-for="AnoPublicacao" class="livro-label">Ano de Publicação</label>
                <input asp-for="AnoPublicacao" type="number" class="form-control-livro" placeholder="0" required>
            </div>

            <button type="submit" class="btn-salvar-livro">Salvar</button>
            
        </form>

        @if (ViewBag.Messagem != null)
        {
            <div class="alert alert-info mt-3">@ViewBag.Mensagem</div>
        }
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
